# Copy to .env.local and fill in. .env* is gitignored — never commit real values.
#
# Every variable here is optional. With none of them set the site runs exactly
# as it always has: analytics silently no-op, and /admin refuses to open. That's
# deliberate, so a fresh clone works with no setup at all.

# ---------------------------------------------------------------- analytics
# Neon Postgres connection string (https://neon.tech — free tier, no card).
# Create a project, copy the pooled connection string, paste it here.
# Unset = /api/track accepts requests and does nothing with them.
DATABASE_URL=

# Salt for the daily-rotating IP hash used for rate limiting.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Unset = no IP hash is stored at all (fails safe: the site stores less, not
# more — an unsalted hash of an IP is trivially reversible, so it's never used).
ANALYTICS_SALT=

# ------------------------------------------------------------------- /admin
# Both must be set or /admin is unreachable. It fails closed on purpose: a
# forgotten variable must never publish every visitor's analytics.
#
# Both have an ENFORCED minimum length, not a suggested one — too short and
# /admin stays shut and logs why. This repository is public, so an attacker can
# read exactly how the auth works; that's fine by design, but it means the
# password is doing the work and a memorable one throws the whole thing away.
#
# ADMIN_PASSWORD is what you type. Minimum 16 characters. Generate, don't invent:
#   node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ADMIN_PASSWORD=
# HMAC key signing the admin session token. Minimum 32 characters — a guessable
# signing key doesn't need the password at all, it just forges a token.
# There is no cookie: the token is held in memory by the dashboard, so it dies
# on refresh and on tab close. Rotating this kills every live token instantly.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=

# --------------------------------------------------------------------- misc
# Overrides the canonical origin used for canonical tags, OG images and the
# sitemap. Only needed for a self-host on a different domain — production
# resolves to https://mysuvo.com from src/lib/site.ts on its own.
# NEXT_PUBLIC_SITE_URL=

# Optional. Raises the GitHub API rate limit for /api/github from 60/hr to
# 5000/hr. A read-only token with NO scopes is enough — it only reads public
# repos. Absent is fine; the route degrades to the unauthenticated limit.
# GITHUB_TOKEN=
